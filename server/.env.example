# ========================================
# CONFIGURACIÓN DE GOOGLE OAUTH 2.0
# ========================================
# Pasos para obtener las credenciales:
# 1. Ve a https://console.cloud.google.com
# 2. Crea un nuevo proyecto o selecciona uno existente
# 3. Habilita la API de Google+ (o "People API")
# 4. Va a "Credenciales" y crea una nueva credencial: "OAuth 2.0 ID de Cliente"
# 5. Selecciona "Aplicación web"
# 6. En "Orígenes autorizados" agrega:
#    - http://localhost:3000
#    - http://localhost:5000
#    - http://localhost:5173
#    - https://tu-dominio.com (cuando despliegues)
# 7. En "URIs de redirección autorizados" agrega:
#    - http://localhost:5000/api/auth/callback
#    - http://localhost:5173/auth/callback
#    - https://tu-dominio.com/auth/callback (cuando despliegues)
# 8. Copia el Client ID y Client Secret y pégalos aquí:

GOOGLE_CLIENT_ID=tu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_google_client_secret_aqui

# ========================================
# CONFIGURACIÓN DE JWT
# ========================================
JWT_SECRET=tu_jwt_secret_super_seguro_aqui_min_32_caracteres
REFRESH_TOKEN_SECRET=tu_refresh_secret_super_seguro_aqui_min_32_caracteres
ALLOW_AUTH_HEADER_FALLBACK=true

# ========================================
# GOOGLE GEMINI (Transcripcion)
# ========================================
GEMINI_API_KEY=tu_api_key_de_gemini
GEMINI_MODEL=gemini-1.5-flash-002

# ========================================
# PUERTO DEL SERVIDOR
# ========================================
PORT=5000

# ========================================
# BASE DE DATOS (Ya existente)
# ========================================
DATABASE_URL=postgresql://neondb_owner:npg_************@ep-empty-band-aiyzwi0n.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ========================================
# EMAIL AUTORIZADO
# ========================================
AUTHORIZED_EMAIL=centrokareh@gmail.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx


# ========================================
# ENTORNO
# ========================================
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Orígenes extra separados por coma para CORS en producción
# Ejemplo: https://agenda-kareh.vercel.app,https://mi-preview.vercel.app
CORS_ALLOWED_ORIGINS=

# ========================================
# STORAGE (S3 / R2 / Compatible)
# ========================================
# Bucket y credenciales
STORAGE_BUCKET=mi-bucket
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=xxxxxxxx
STORAGE_SECRET_ACCESS_KEY=xxxxxxxx
# Endpoint opcional para S3-compatible (R2/MinIO)
# STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# URL pública base (recomendada)
# STORAGE_PUBLIC_URL=https://cdn.mi-dominio.com
# Tamaño máximo de archivo (MB)
UPLOAD_MAX_MB=25
TRANSCRIPTION_MAX_MB=8

# ========================================
# WHATSAPP CLOUD API
# ========================================
WHATSAPP_ACCESS_TOKEN=tu_token
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id
WHATSAPP_API_VERSION=v20.0
WHATSAPP_TEMPLATE_LANGUAGE=es_AR
WHATSAPP_TICKET_TEMPLATE=nombre_template_ticket
WHATSAPP_REMINDER_TEMPLATE=nombre_template_recordatorio
WHATSAPP_WELCOME_TEMPLATE=bienvenida_kareh
WHATSAPP_HOLA_TEMPLATE=bienvenida_kareh
WHATSAPP_WELCOME_MODE=text
WHATSAPP_HOLA_MODE=text
# Puedes escribir el mensaje con "\n" para conservar saltos de línea si lo cargas en una sola línea.
WHATSAPP_WELCOME_TEXT=¡Hola! {{1}} Bienvenido/a a Kinesiología Kareh 🌿. Para asesorarte mejor, enviá el número de tu opción:\n\n1️⃣ Obra Social\n2️⃣ Particular\n3️⃣ PAMI\n4️⃣ Respiratorio\n\n📍 Av. Senador Morón 782, Bella Vista.\n\n⏰ Atención: Lun y Vie (14-19hs) / Mar, Mié y Jue (17:30-19hs) / Sáb (8-12hs).\n\n¡Estamos procesando tu mensaje y te responderemos a la brevedad! ✨🏥
WHATSAPP_HOLA_TEXT=
# Si el template usa variables con nombre, indicar los nombres separados por coma.
# Ejemplo: nombre o nombre_paciente. Usar NONE si el body no lleva variables.
WHATSAPP_WELCOME_TEMPLATE_BODY_PARAMS=
WHATSAPP_HOLA_TEMPLATE_BODY_PARAMS=
WHATSAPP_WELCOME_FALLBACK_TEXT=
WHATSAPP_WELCOME_COOLDOWN_HOURS=24
WHATSAPP_VERIFY_TOKEN=token_verificacion_webhook
WHATSAPP_DEFAULT_COUNTRY_CODE=54
WHATSAPP_REMINDER_WINDOW_MINUTES=60
WHATSAPP_CRON_TOKEN=token_secreto

# Zona horaria para cron
TZ=America/Argentina/Buenos_Aires

# (No incluir llaves reales en este archivo)
