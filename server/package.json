{
  "name": "kareh-server",
  "version": "1.0.0",
  "description": "Backend for KAREH medical agenda",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node scripts/bootstrap-production.js",
    "postinstall": "node scripts/install-puppeteer-chrome.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect-brk node_modules/.bin/jest --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "check:auth": "node scripts/check-auth-config.js",
    "check:db": "node scripts/check-db.js",
    "check:whatsapp": "node scripts/check-whatsapp-config.js",
    "smoke:deploy": "node scripts/smoke-check.js",
    "backfill:honorarios": "node scripts/backfill-appointment-honorarios.js --apply",
    "check-whatsapp": "npm run check:whatsapp",
    "whatsapp-reminders": "node scripts/whatsapp-reminders.js",
    "cokiba-sync": "node scripts/cokiba-sync.js"
  },
  "engines": {
    "node": "22.x"
  },
  "keywords": [],
  "author": "Jose Arturo Azocar Perez",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1021.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "date-fns": "^3.6.0",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "p-queue": "^8.1.1",
    "pdfkit": "^0.15.2",
    "puppeteer": "^24.9.0",
    "resend": "^6.9.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@types/jest": "^30.0.0",
    "babel-jest": "^30.4.1",
    "jest": "^30.4.2",
    "nodemon": "^3.1.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "brace-expansion": "^1.1.13",
    "minimatch": "^3.1.4",
    "path-to-regexp": "0.1.13",
    "picomatch": "^2.3.2",
    "qs": "^6.15.0",
    "cookie": "^0.7.0",
    "fast-xml-parser": "5.7.3",
    "uuid": "14.0.0",
    "@hono/node-server": "^1.19.14"
  }
